{
	"name": "@astrojs/codemirror-astro",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "CodeMirror 6 language support for Astro (.astro) files.",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"files": ["dist", "src"],
	"scripts": {
		"build:grammar": "node scripts/build-grammar.mjs",
		"build": "node scripts/build-grammar.mjs && tsup",
		"dev": "tsup --watch"
	},
	"dependencies": {
		"@lezer/highlight": "^1.2.3",
		"@lezer/lr": "^1.4.10"
	},
	"peerDependencies": {
		"@codemirror/language": "^6.12.0",
		"@lezer/common": "^1.5.0",
		"@lezer/css": "^1.3.0",
		"@lezer/html": "^1.3.0",
		"@lezer/javascript": "^1.5.0"
	},
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@lezer/common": "^1.5.2",
		"@lezer/css": "^1.3.3",
		"@lezer/generator": "^1.8.0",
		"@lezer/html": "^1.3.13",
		"@lezer/javascript": "^1.5.4",
		"tsup": "^8.5.1",
		"typescript": "^5.6.0"
	}
}
