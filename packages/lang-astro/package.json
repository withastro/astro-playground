{
	"name": "@astrojs/codemirror-astro",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "CodeMirror 6 language support for Astro (.astro) files.",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build:grammar": "node scripts/build-grammar.mjs",
		"build": "node scripts/build-grammar.mjs && tsdown",
		"dev": "tsdown --watch",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@lezer/highlight": "^1.2.3",
		"@lezer/lr": "^1.4.10",
		"@lezer/common": "^1.5.0",
		"@lezer/css": "^1.3.0",
		"@lezer/javascript": "^1.5.0"
	},
	"peerDependencies": {
		"@codemirror/language": "^6.12.0"
	},
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@lezer/common": "^1.5.2",
		"@lezer/css": "^1.3.3",
		"@lezer/generator": "^1.8.0",
		"@lezer/javascript": "^1.5.4",
		"tsdown": "^0.8.0",
		"typescript": "^5.6.0"
	}
}
