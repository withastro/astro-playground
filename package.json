{
	"name": "astro-playground",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"engines": {
		"node": "24.18.0"
	},
	"scripts": {
		"dev": "pnpm --filter playground run dev",
		"build": "pnpm --filter playground run build",
		"preview": "pnpm --filter playground run preview",
		"lang:build": "pnpm --filter @astrojs/codemirror-astro run build",
		"lint:ai": "biome check --reporter=concise",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"check": "pnpm --filter ./packages/playground --filter ./packages/lang-astro run check"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1"
	}
}
